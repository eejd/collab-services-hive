# ============================================================================
# collab-services-hive — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values, then run: cshive verify
#
# Two compose stacks:
#   docker-compose.yml       — primary node (Mac Mini / Colima): bridges
#   docker-compose.vps.yml   — Gandi VPS: Continuwuity + Caddy + wsproxy
# ============================================================================

# ── Identity ──────────────────────────────────────────────────────────────────
PUID=942
PGID=942
TZ=America/New_York

# ── Docker / Colima (primary node) ───────────────────────────────────────────
COMPOSE_PROJECT_NAME=collab
COLIMA_PROFILE=default

# ── Matrix Domain ─────────────────────────────────────────────────────────────
# Public domain used for Matrix federation and client-server API.
# DNS: matrix.${MATRIX_DOMAIN} A → VPS public IP (static)
# Caddy issues TLS certs for this domain automatically.
MATRIX_DOMAIN=example.com
MATRIX_SERVER_NAME=matrix.example.com

# ── ZeroTier Network ──────────────────────────────────────────────────────────
# ZeroTier IP of the Gandi VPS — used in bridge homeserver.url and
# appservice registration YAMLs so the homeserver can call back to bridges.
COLLAB_VPS_ZT_IP=

# ZeroTier IP of the M4 Mac Mini (primary node) — used in homeserver's
# appservice configuration so Continuwuity knows where to POST bridge events.
COLLAB_PRIMARY_ZT_IP=

# ── VPS Access ────────────────────────────────────────────────────────────────
# SSH target for the Gandi VPS. cshive uses DOCKER_HOST=ssh://${COLLAB_VPS_SSH_HOST}
# to run docker compose commands remotely without copying the compose file.
COLLAB_VPS_SSH_HOST=hive@

# Path to the SSH private key for VPS access.
# The matching public key must be in ~/.ssh/authorized_keys on the VPS (hive user).
COLLAB_VPS_SSH_KEY=~/.ssh/hive_ed25519

# ── Storage — Primary Node ────────────────────────────────────────────────────
# Bind-mount root for bridge config files on the Mac Mini.
# Bridge state (session DBs) uses named Docker volumes — not bind mounts.
COLLAB_CONFIG_ROOT=/zfs/Config/collab

# Backup destination for VPS data (rsync target, covered by ZFS → Backblaze).
COLLAB_BACKUP_ROOT=/zfs/Backup/hive/collab

# ── Storage — VPS ─────────────────────────────────────────────────────────────
# Bind-mount root for homeserver/Caddy config on the VPS filesystem.
# Named volumes (collab_continuwuity_data etc.) are created by Docker on the VPS.
COLLAB_VPS_CONFIG_ROOT=/opt/collab

# ── Continuwuity ──────────────────────────────────────────────────────────────
# Continuwuity client-server API port (internal; Caddy proxies this publicly).
CONTINUWUITY_PORT=6167

# Registration shared secret — set this to a long random string.
# Used to register appservices with the homeserver.
# Generate: openssl rand -hex 32
CONTINUWUITY_REGISTRATION_SHARED_SECRET=

CONTINUWUITY_VERSION=latest

# ── Caddy ─────────────────────────────────────────────────────────────────────
# Email for Let's Encrypt ACME registration (used in Caddyfile).
ACME_EMAIL=

CADDY_VERSION=latest

# ── mautrix-wsproxy ───────────────────────────────────────────────────────────
# Shared secrets for iMessage relay — set to long random strings.
# Generate: openssl rand -hex 32
WSPROXY_AS_TOKEN=
WSPROXY_HS_TOKEN=

WSPROXY_VERSION=latest

# ── Bridge Appservice Ports ────────────────────────────────────────────────────
# Ports the homeserver (VPS) uses to POST events to each bridge (primary node).
# Must be reachable at COLLAB_PRIMARY_ZT_IP from the VPS.
# Published in docker-compose.yml so the Mac Mini forwards them from ZT interface.
SIGNAL_APPSERVICE_PORT=29328
WHATSAPP_APPSERVICE_PORT=29318
DISCORD_APPSERVICE_PORT=29334

# ── Bridge Versions ───────────────────────────────────────────────────────────
MAUTRIX_SIGNAL_VERSION=latest
MAUTRIX_WHATSAPP_VERSION=latest
MAUTRIX_DISCORD_VERSION=latest

# ── Pinned Service Versions ───────────────────────────────────────────────────
# Pin to digests or semver tags in production to prevent silent upgrades.
# Example: CONTINUWUITY_VERSION=sha256:abc123...
