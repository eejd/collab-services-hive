#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/hive.sh
source "${PROJECT_ROOT}/scripts/lib/hive.sh"

usage() {
    cat <<EOF
cshive — collab-services-hive lifecycle manager

LIFECYCLE:
    start   [vps|primary|private|all]   Start services (default: all)
    stop    [vps|primary|private|all]   Stop services (default: all)
    restart [vps|primary|private|all]   Restart services (default: all)
    status  [vps|primary|private|all]   Show service status (default: all)
    update  [vps|primary|private|all]   Pull latest images and restart (default: all)

PRIVATE SERVER SETUP (home.zt — run once before first start):
    private-setup               Deploy home.zt config to COLLAB_CONFIG_ROOT

VPS SETUP (sibeling.org — run once before first deploy):
    vps-setup                   Create VPS directories and deploy config files
    vps-ufw                     Configure VPS firewall (UFW) for Matrix services
    vps-deploy-config           Re-deploy config files to VPS (after editing templates)

OPERATIONS:
    backup                      VPS RocksDB cold backup + local bridge volume export
    backup-status               Show last backup age for VPS + all local bridge volumes
    verify                      Preflight: ZeroTier, SSH, homeserver health, hive-net
    logs <service>              Tail logs (signal|whatsapp|discord|continuwuity|continuwuity-private|wsproxy|caddy)

FIRST DEPLOY — private homeserver (home.zt):
    1. cp .env.example .env && \$EDITOR .env
    2. cshive private-setup      # deploy config files
    3. cshive start private      # start homeserver
    4. Configure Element: set homeserver URL to http://matrix.home.zt

FIRST DEPLOY — public homeserver (sibeling.org VPS):
    1. cshive verify             # check connectivity
    2. cshive vps-setup          # deploy config to VPS
    3. cshive vps-ufw            # configure firewall
    4. cshive start vps          # start homeserver

EXAMPLES:
    cshive start private        # start home.zt homeserver only
    cshive logs continuwuity-private  # tail private homeserver logs
    cshive start                # start all stacks
    cshive status               # show all service status
    cshive backup               # cold backup VPS RocksDB to /zfs/Backup/hive/collab/
    cshive update primary       # pull new bridge images and restart
    cshive vps-deploy-config    # push updated Caddyfile/continuwuity.toml to VPS
EOF
}

_load_vars() {
    load_env
    COLIMA_PROFILE="${COLIMA_PROFILE:-default}"
    CONTINUWUITY_PORT="${CONTINUWUITY_PORT:-6167}"
    PRIVATE_CONTINUWUITY_PORT="${PRIVATE_CONTINUWUITY_PORT:-6168}"
    PRIVATE_SERVER_NAME="${PRIVATE_SERVER_NAME:-home.zt}"
    COLLAB_BACKUP_ROOT="${COLLAB_BACKUP_ROOT:-/zfs/Backup/hive/collab}"
    COLLAB_LOCAL_BACKUP_ROOT="${COLLAB_LOCAL_BACKUP_ROOT:-/zfs/Backup/hive/collab-local}"
    COLLAB_VPS_CONFIG_ROOT="${COLLAB_VPS_CONFIG_ROOT:-/opt/collab}"
}

# ── SSH / SCP helpers ─────────────────────────────────────────────────────────

_ssh_vps() {
    local key_path="${COLLAB_VPS_SSH_KEY:-}"
    if [[ -n "${key_path}" ]]; then
        ssh -i "${key_path/#\~/${HOME}}" "${COLLAB_VPS_SSH_HOST}" "$@"
    else
        ssh "${COLLAB_VPS_SSH_HOST}" "$@"
    fi
}

_scp_to_vps() {
    local src="$1" dest="$2"
    local key_path="${COLLAB_VPS_SSH_KEY:-}"
    if [[ -n "${key_path}" ]]; then
        scp -i "${key_path/#\~/${HOME}}" "${src}" "${COLLAB_VPS_SSH_HOST}:${dest}"
    else
        scp "${src}" "${COLLAB_VPS_SSH_HOST}:${dest}"
    fi
}

# ── Compose helpers ───────────────────────────────────────────────────────────

_compose_primary() {
    export_docker_host
    require_docker
    docker compose -f "${PROJECT_ROOT}/docker-compose.yml" "$@"
}

_compose_private() {
    export_docker_host
    require_docker
    docker compose -f "${PROJECT_ROOT}/docker-compose.yml" --profile private "$@"
}

# Deploy wsproxy environment file to VPS (/etc/wsproxy/wsproxy.env).
_vps_deploy_wsproxy_env() {
    require_env WSPROXY_AS_TOKEN WSPROXY_HS_TOKEN
    printf 'LISTEN_ADDRESS=0.0.0.0:29331\nAS_TOKEN=%s\nHS_TOKEN=%s\n' \
        "${WSPROXY_AS_TOKEN}" "${WSPROXY_HS_TOKEN}" \
        | _ssh_vps "sudo tee /etc/wsproxy/wsproxy.env > /dev/null"
    _ssh_vps "sudo chmod 600 /etc/wsproxy/wsproxy.env"
}

# Update wsproxy binary to WSPROXY_VERSION on the VPS.
_vps_update_wsproxy() {
    local version="${WSPROXY_VERSION:-}"
    if [[ -z "${version}" ]]; then
        log_warn "WSPROXY_VERSION not set in .env — skipping wsproxy binary update"
        return
    fi
    local arch; arch="$(_ssh_vps "uname -m")"
    local deb_arch
    case "${arch}" in
        x86_64)  deb_arch="amd64" ;;
        aarch64) deb_arch="arm64" ;;
        *) log_error "Unsupported VPS arch: ${arch}"; return 1 ;;
    esac
    local url="https://github.com/mautrix/wsproxy/releases/download/v${version}/wsproxy-linux-${deb_arch}"
    log_info "Downloading wsproxy ${version} (${deb_arch})"
    _ssh_vps "sudo curl -fsSL '${url}' -o /usr/local/bin/wsproxy && sudo chmod +x /usr/local/bin/wsproxy"
}

# ── Lifecycle ─────────────────────────────────────────────────────────────────

run_start() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Starting VPS stack (Continuwuity + Caddy + wsproxy)"
            require_env COLLAB_VPS_SSH_HOST
            _ssh_vps "sudo systemctl start continuwuity caddy wsproxy"
            log_ok "VPS stack started"
            ;;
        primary)
            log_step "Starting primary stack (bridges)"
            docker network create hive-net 2>/dev/null || true
            _compose_primary up -d
            log_ok "Primary stack started"
            ;;
        private)
            log_step "Starting private homeserver (${PRIVATE_SERVER_NAME})"
            docker network create hive-net 2>/dev/null || true
            _compose_private up -d continuwuity-private
            log_ok "Private homeserver started"
            log_info "Connect Element: set homeserver URL to http://matrix.${PRIVATE_SERVER_NAME}"
            ;;
        all)
            run_start vps
            run_start primary
            run_start private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_stop() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Stopping VPS stack"
            require_env COLLAB_VPS_SSH_HOST
            _ssh_vps "sudo systemctl stop wsproxy caddy continuwuity"
            log_ok "VPS stack stopped"
            ;;
        primary)
            log_step "Stopping primary stack"
            _compose_primary down
            log_ok "Primary stack stopped"
            ;;
        private)
            log_step "Stopping private homeserver"
            _compose_private down --remove-orphans
            log_ok "Private homeserver stopped"
            ;;
        all)
            run_stop private
            run_stop primary
            run_stop vps
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_restart() {
    local target="${1:-all}"
    run_stop "${target}"
    run_start "${target}"
}

run_status() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "VPS stack status"
            if [[ -z "${COLLAB_VPS_SSH_HOST:-}" ]]; then
                log_warn "COLLAB_VPS_SSH_HOST not set — skipping VPS status (set in .env to enable)"
            else
                _ssh_vps "sudo systemctl status continuwuity caddy wsproxy" 2>/dev/null || \
                    log_warn "VPS unreachable at ${COLLAB_VPS_SSH_HOST} — is SSH accessible? (run: cshive vps-setup)"
            fi
            ;;
        primary)
            log_step "Primary stack status"
            _compose_primary ps
            ;;
        private)
            log_step "Private homeserver status"
            _compose_private ps continuwuity-private
            ;;
        all)
            run_status vps
            echo ""
            run_status primary
            echo ""
            run_status private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_update() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Updating VPS services"
            require_env COLLAB_VPS_SSH_HOST
            _ssh_vps "sudo apt-get install -y --only-upgrade continuwuity caddy"
            _vps_update_wsproxy
            _ssh_vps "sudo systemctl restart continuwuity caddy wsproxy"
            log_ok "VPS stack updated and restarted"
            ;;
        primary)
            log_step "Updating primary stack images"
            _compose_primary pull
            _compose_primary up -d
            log_ok "Primary stack updated"
            ;;
        private)
            log_step "Updating private homeserver image"
            _compose_private pull continuwuity-private
            _compose_private up -d continuwuity-private
            log_ok "Private homeserver updated"
            ;;
        all)
            run_update vps
            run_update primary
            run_update private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

# ── Private Server Setup (home.zt) ───────────────────────────────────────────

run_private_setup() {
    require_env COLLAB_CONFIG_ROOT PRIVATE_SERVER_NAME PRIVATE_CONTINUWUITY_PORT

    local config_dir="${COLLAB_CONFIG_ROOT}/continuwuity-private"
    local toml_tpl="${PROJECT_ROOT}/config/continuwuity/continuwuity-private.toml.example"

    log_step "1/2 Creating config directory: ${config_dir}"
    mkdir -p "${config_dir}"
    log_ok "Directory ready"

    log_step "2/2 Deploying continuwuity.toml for ${PRIVATE_SERVER_NAME}"
    if [[ ! -f "${toml_tpl}" ]]; then
        log_error "Template not found: ${toml_tpl}"
        exit 1
    fi
    envsubst < "${toml_tpl}" > "${config_dir}/continuwuity.toml"
    log_ok "Config deployed to ${config_dir}/continuwuity.toml"
    log_warn "server_name is set to '${PRIVATE_SERVER_NAME}' — permanent after first start"

    log_ok "Private server setup complete"
    log_info "Next: cshive start private"
    log_info "Then: configure Element homeserver URL → http://matrix.${PRIVATE_SERVER_NAME}"
    log_info "After creating your account, set allow_registration = false in the config"
    log_info "and run: cshive restart private"
}

# ── VPS Setup ────────────────────────────────────────────────────────────────

run_vps_setup() {
    require_env COLLAB_VPS_SSH_HOST MATRIX_SERVER_NAME MATRIX_DOMAIN \
                CONTINUWUITY_PORT CONTINUWUITY_REGISTRATION_SHARED_SECRET \
                ACME_EMAIL WSPROXY_AS_TOKEN WSPROXY_HS_TOKEN

    local install_script="${PROJECT_ROOT}/scripts/vps-install.sh"
    local toml_tpl="${PROJECT_ROOT}/config/continuwuity/continuwuity.toml.example"
    [[ -f "${install_script}" ]] || { log_error "Missing: ${install_script}"; exit 1; }
    [[ -f "${toml_tpl}" ]]       || { log_error "Missing: ${toml_tpl}"; exit 1; }

    log_step "1/5 Uploading vps-install.sh"
    _scp_to_vps "${install_script}" "/tmp/vps-install.sh"
    log_ok "Uploaded"

    log_step "2/5 Running vps-install.sh (installs packages, creates users, enables services)"
    _ssh_vps "sudo bash /tmp/vps-install.sh '${WSPROXY_VERSION:-1.0.0}'"
    log_ok "Installation complete"

    log_step "3/5 Deploying continuwuity.toml"
    envsubst < "${toml_tpl}" | _ssh_vps "sudo tee /etc/continuwuity/continuwuity.toml > /dev/null"
    log_ok "continuwuity.toml deployed (server_name=${MATRIX_SERVER_NAME})"

    log_step "4/5 Deploying Caddyfile"
    _scp_to_vps "${PROJECT_ROOT}/config/caddy/Caddyfile.example" "/tmp/cshive-Caddyfile"
    _ssh_vps "sudo mv /tmp/cshive-Caddyfile /etc/caddy/Caddyfile"
    log_ok "Caddyfile deployed"

    log_step "5/5 Deploying wsproxy environment"
    _vps_deploy_wsproxy_env
    log_ok "wsproxy.env deployed"

    log_ok "VPS setup complete"
    log_info "Next steps:"
    log_info "  cshive vps-ufw    — configure UFW firewall rules"
    log_info "  cshive start vps  — start all VPS services"
}

run_vps_ufw() {
    require_env COLLAB_VPS_SSH_HOST ZT_SUBNET CONTINUWUITY_PORT

    log_step "Configuring UFW on VPS (ZeroTier subnet: ${ZT_SUBNET})"

    # Public ports — Matrix federation and client API via Caddy
    _ssh_vps "sudo ufw allow 80/tcp comment 'Caddy ACME HTTP-01'"
    _ssh_vps "sudo ufw allow 443/tcp comment 'Matrix client-server API'"
    _ssh_vps "sudo ufw allow 8448/tcp comment 'Matrix server-to-server federation'"

    # ZeroTier-only — homeserver API for bridges and MCP server on primary node
    _ssh_vps "sudo ufw allow from ${ZT_SUBNET} to any port ${CONTINUWUITY_PORT} proto tcp comment 'Matrix homeserver API (ZeroTier only)'"

    # ZeroTier-only — wsproxy for iMessage satellite (Mac Mini)
    _ssh_vps "sudo ufw allow from ${ZT_SUBNET} to any port 29331 proto tcp comment 'mautrix-wsproxy (ZeroTier only)'"

    log_ok "UFW rules applied"
    _ssh_vps "sudo ufw status numbered"
}

run_vps_deploy_config() {
    require_env COLLAB_VPS_SSH_HOST MATRIX_SERVER_NAME MATRIX_DOMAIN \
                CONTINUWUITY_PORT CONTINUWUITY_REGISTRATION_SHARED_SECRET \
                ACME_EMAIL WSPROXY_AS_TOKEN WSPROXY_HS_TOKEN

    log_step "Re-deploying config files to VPS"

    log_info "Deploying continuwuity.toml"
    envsubst < "${PROJECT_ROOT}/config/continuwuity/continuwuity.toml.example" \
        | _ssh_vps "sudo tee /etc/continuwuity/continuwuity.toml > /dev/null"

    log_info "Deploying Caddyfile"
    _scp_to_vps "${PROJECT_ROOT}/config/caddy/Caddyfile.example" "/tmp/cshive-Caddyfile"
    _ssh_vps "sudo mv /tmp/cshive-Caddyfile /etc/caddy/Caddyfile"

    log_info "Deploying wsproxy.env"
    _vps_deploy_wsproxy_env

    log_ok "Config files deployed"
    log_info "Reloading Caddy (no restart needed for Caddyfile changes)"
    _ssh_vps "sudo systemctl reload caddy" 2>/dev/null || \
        log_warn "Caddy reload failed — run: cshive restart vps"
    log_info "Restart continuwuity to apply toml changes: cshive restart vps"
}

# ── Backup ────────────────────────────────────────────────────────────────────

_export_local_volume() {
    local short_name="$1"
    local dest_dir="$2"
    local full_name="${COMPOSE_PROJECT_NAME:-collab-services-hive}_${short_name}"

    if ! docker volume inspect "${full_name}" &>/dev/null 2>&1; then
        log_info "Volume not found (not yet created): ${full_name} — skipping"
        return 0
    fi

    local vol_dest="${dest_dir}/${short_name}"
    mkdir -p "${vol_dest}"
    log_info "Exporting ${full_name}…"
    docker run --rm \
        -v "${full_name}:/data:ro" \
        -v "${vol_dest}:/backup" \
        alpine \
        sh -c "tar czf /backup/data.tar.gz -C /data . 2>/dev/null || tar cf /backup/data.tar.gz -C /data ."
    local size; size="$(du -sh "${vol_dest}/data.tar.gz" 2>/dev/null | awk '{print $1}' || echo "?")"
    log_ok "  ${short_name}: ${size} → ${vol_dest}/data.tar.gz"
}

run_backup() {
    require_env COLLAB_VPS_SSH_HOST
    local today; today="$(date +%Y-%m-%d)"
    local dest="${COLLAB_BACKUP_ROOT}/${today}"
    local latest="${COLLAB_BACKUP_ROOT}/latest"
    local vol_path="/var/lib/continuwuity"

    log_step "1/2 Cold backup of VPS RocksDB → ${dest}"
    log_warn "Continuwuity will be stopped briefly (~30–60s)"

    log_step "1a Stopping Continuwuity on VPS"
    _ssh_vps "sudo systemctl stop continuwuity"

    log_step "1b Rsyncing ${COLLAB_VPS_SSH_HOST}:${vol_path}/ → ${dest}/"
    mkdir -p "${dest}"
    local link_arg=""
    [[ -d "${latest}" ]] && link_arg="--link-dest=${latest}"
    local ssh_opt="-o StrictHostKeyChecking=accept-new"
    if [[ -n "${COLLAB_VPS_SSH_KEY:-}" ]]; then
        ssh_opt="${ssh_opt} -i ${COLLAB_VPS_SSH_KEY/#\~/${HOME}}"
    fi
    rsync -az --delete --rsync-path="sudo rsync" \
        -e "ssh ${ssh_opt}" \
        ${link_arg} \
        "${COLLAB_VPS_SSH_HOST}:${vol_path}/" \
        "${dest}/"
    ln -sfn "${dest}" "${latest}"
    log_ok "VPS backup complete: ${dest}"

    log_step "1c Restarting Continuwuity on VPS"
    _ssh_vps "sudo systemctl start continuwuity"
    log_ok "Continuwuity restarted"

    log_step "Rotating VPS backups (keeping last 30 days)"
    _rotate_backups

    log_step "2/2 Exporting local bridge volumes → ${COLLAB_LOCAL_BACKUP_ROOT}"
    export_docker_host
    local ts; ts="$(date +%Y%m%d-%H%M%S)"
    local local_dest="${COLLAB_LOCAL_BACKUP_ROOT}/${ts}"
    mkdir -p "${local_dest}"
    for vol in collab_signal_data collab_whatsapp_data collab_discord_data collab_private_data; do
        _export_local_volume "${vol}" "${local_dest}"
    done

    log_step "Rotating local volume exports (keeping 7 most recent)"
    # shellcheck disable=SC2012
    local old; old="$(ls -1dt "${COLLAB_LOCAL_BACKUP_ROOT}"/[0-9]*-[0-9]* 2>/dev/null | tail -n +8)"
    [[ -n "${old}" ]] && echo "${old}" | xargs rm -rf && log_ok "Old local exports pruned"

    log_ok "Backup complete (VPS + local bridges)"
}

run_backup_status() {
    local now; now=$(date +%s)
    local threshold_hours=48
    local all_ok=true

    printf "%-28s  %-22s  %6s  %s\n" "VOLUME / SERVICE" "LAST BACKUP" "AGE" "STATUS"
    printf '%.0s─' {1..72}; echo

    # VPS RocksDB — check via COLLAB_BACKUP_ROOT/latest symlink mtime
    local vps_label="continuwuity (VPS RocksDB)"
    local vps_latest="${COLLAB_BACKUP_ROOT}/latest"
    if [[ -d "${vps_latest}" ]]; then
        local mtime; mtime=$(stat -f %m "${vps_latest}" 2>/dev/null || stat -c %Y "${vps_latest}")
        local age_h=$(( (now - mtime) / 3600 ))
        local ts; ts=$(date -r "${mtime}" "+%Y-%m-%d %H:%M" 2>/dev/null || date -d "@${mtime}" "+%Y-%m-%d %H:%M")
        if (( age_h < threshold_hours )); then
            printf "%-28s  %-22s  %4dh  ✓\n" "${vps_label}" "${ts}" "${age_h}"
        else
            printf "%-28s  %-22s  %4dh  ⚠ STALE\n" "${vps_label}" "${ts}" "${age_h}"
            all_ok=false
        fi
    else
        printf "%-28s  %-22s  %6s  ✗ MISSING\n" "${vps_label}" "—" "—"
        all_ok=false
    fi

    # Local bridge volumes — newest tar.gz per volume under COLLAB_LOCAL_BACKUP_ROOT
    for vol in collab_signal_data collab_whatsapp_data collab_discord_data collab_private_data; do
        local newest=""
        newest=$(find "${COLLAB_LOCAL_BACKUP_ROOT}" -path "*/${vol}/data.tar.gz" -type f 2>/dev/null \
            | sort | tail -1)
        if [[ -z "${newest}" ]]; then
            printf "%-28s  %-22s  %6s  ✗ MISSING\n" "${vol}" "—" "—"
            all_ok=false
            continue
        fi
        local mtime; mtime=$(stat -f %m "${newest}" 2>/dev/null || stat -c %Y "${newest}")
        local age_h=$(( (now - mtime) / 3600 ))
        local size; size=$(du -sh "${newest}" 2>/dev/null | cut -f1)
        local ts; ts=$(date -r "${mtime}" "+%Y-%m-%d %H:%M" 2>/dev/null || date -d "@${mtime}" "+%Y-%m-%d %H:%M")
        if (( age_h < threshold_hours )); then
            printf "%-28s  %-22s  %4dh  ✓ (%s)\n" "${vol}" "${ts}" "${age_h}" "${size}"
        else
            printf "%-28s  %-22s  %4dh  ⚠ STALE (%s)\n" "${vol}" "${ts}" "${age_h}" "${size}"
            all_ok=false
        fi
    done

    echo ""
    if $all_ok; then
        log_ok "All collab backups fresh (< ${threshold_hours}h)."
        return 0
    else
        log_error "One or more backups are missing or stale."
        return 1
    fi
}

_rotate_backups() {
    local cutoff; cutoff="$(date -v-31d +%Y-%m-%d 2>/dev/null || date -d '31 days ago' +%Y-%m-%d)"
    local count=0
    for dir in "${COLLAB_BACKUP_ROOT}"/????-??-??; do
        [[ -d "${dir}" ]] || continue
        local name; name="$(basename "${dir}")"
        if [[ "${name}" < "${cutoff}" ]]; then
            rm -rf "${dir}"
            (( count++ ))
        fi
    done
    [[ ${count} -gt 0 ]] && log_info "Removed ${count} backup(s) older than 30 days"
}

# ── Verify ────────────────────────────────────────────────────────────────────

run_verify() {
    local ok=true
    require_env COLLAB_VPS_ZT_IP COLLAB_PRIMARY_ZT_IP COLLAB_VPS_SSH_HOST MATRIX_DOMAIN

    log_step "1. ZeroTier connectivity to VPS (${COLLAB_VPS_ZT_IP})"
    if ping -c 1 -W 2 "${COLLAB_VPS_ZT_IP}" &>/dev/null; then
        log_ok "VPS ZeroTier reachable"
    else
        log_error "Cannot ping VPS at ${COLLAB_VPS_ZT_IP}"
        log_info  "Check: is ZeroTier running? Is the VPS joined to the network?"
        ok=false
    fi

    log_step "2. VPS SSH reachable"
    if ssh -o ConnectTimeout=5 -o BatchMode=yes "${COLLAB_VPS_SSH_HOST}" true 2>/dev/null; then
        log_ok "VPS SSH reachable"
    else
        log_error "SSH to ${COLLAB_VPS_SSH_HOST} failed"
        log_info  "Check: correct key in COLLAB_VPS_SSH_KEY? VPS SSH service running?"
        ok=false
    fi

    log_step "3. VPS systemd services installed"
    if _ssh_vps "systemctl list-unit-files continuwuity.service" 2>/dev/null | grep -q "continuwuity"; then
        log_ok "Continuwuity service present on VPS"
    else
        log_warn "Continuwuity service not found on VPS (run: cshive vps-setup)"
        ok=false
    fi

    log_step "4. Homeserver health (${COLLAB_VPS_ZT_IP}:${CONTINUWUITY_PORT})"
    local hs_url="http://${COLLAB_VPS_ZT_IP}:${CONTINUWUITY_PORT}/_matrix/client/versions"
    if curl -sf --max-time 5 "${hs_url}" -o /dev/null; then
        log_ok "Homeserver responding at ${hs_url}"
    else
        log_warn "Homeserver not responding at ${hs_url} (expected if not yet deployed)"
    fi

    log_step "5. Local Docker (Colima) reachable"
    if colima_running "${COLIMA_PROFILE}"; then
        log_ok "Colima (profile: ${COLIMA_PROFILE}) running"
    else
        log_warn "Colima not running — bridge stack cannot start"
        log_info  "Start: colima start --profile ${COLIMA_PROFILE}"
    fi

    log_step "6. hive-net bridge exists"
    export_docker_host
    if docker network ls --format '{{.Name}}' 2>/dev/null | grep -q '^hive-net$'; then
        log_ok "hive-net bridge present"
    else
        log_warn "hive-net not found — run: docker network create hive-net"
        log_info  "Or: cshive start primary (creates it automatically)"
    fi

    echo ""
    if $ok; then
        log_ok "All required checks passed"
    else
        log_error "Some checks failed — resolve issues before deploying"
        exit 1
    fi
}

# ── Logs ──────────────────────────────────────────────────────────────────────

run_logs() {
    local service="${1:?Usage: cshive logs <service>}"
    case "${service}" in
        signal|whatsapp|discord)
            _compose_primary logs -f "${service}" ;;
        continuwuity-private)
            _compose_private logs -f continuwuity-private ;;
        continuwuity|wsproxy|caddy)
            _ssh_vps "sudo journalctl -u ${service} -f --no-pager" ;;
        *)
            log_error "Unknown service: ${service}"
            log_info  "Valid: signal, whatsapp, discord, continuwuity, continuwuity-private, wsproxy, caddy"
            exit 1
            ;;
    esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true
    [[ "${cmd}" == "help" || "${cmd}" == "--help" || "${cmd}" == "-h" ]] && { usage; exit 0; }
    _load_vars
    case "${cmd}" in
        start)   run_start   "${1:-all}" ;;
        stop)    run_stop    "${1:-all}" ;;
        restart) run_restart "${1:-all}" ;;
        status)  run_status  "${1:-all}" ;;
        update)  run_update  "${1:-all}" ;;
        private-setup)      run_private_setup ;;
        vps-setup)          run_vps_setup ;;
        vps-ufw)            run_vps_ufw ;;
        vps-deploy-config)  run_vps_deploy_config ;;
        backup)         run_backup ;;
        backup-status)  run_backup_status ;;
        verify)         run_verify ;;
        logs)    run_logs "$@" ;;
        *) log_error "Unknown command: ${cmd}"; usage; exit 1 ;;
    esac
}

main "$@"
