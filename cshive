#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/hive.sh
source "${PROJECT_ROOT}/scripts/lib/hive.sh"

usage() {
    cat <<EOF
cshive — collab-services-hive lifecycle manager

LIFECYCLE:
    start   [vps|primary|private|all]   Start services (default: all)
    stop    [vps|primary|private|all]   Stop services (default: all)
    restart [vps|primary|private|all]   Restart services (default: all)
    status  [vps|primary|private|all]   Show service status (default: all)
    update  [vps|primary|private|all]   Pull latest images and restart (default: all)

PRIVATE SERVER SETUP (home.zt — run once before first start):
    private-setup               Deploy home.zt config to COLLAB_CONFIG_ROOT

VPS SETUP (sibeling.org — run once before first deploy):
    vps-setup                   Create VPS directories and deploy config files
    vps-ufw                     Configure VPS firewall (UFW) for Matrix services
    vps-deploy-config           Re-deploy config files to VPS (after editing templates)

OPERATIONS:
    backup                      Cold backup: stop VPS → rsync RocksDB → restart VPS
    verify                      Preflight: ZeroTier, SSH, homeserver health, hive-net
    logs <service>              Tail logs (signal|whatsapp|discord|continuwuity|continuwuity-private|wsproxy|caddy)

FIRST DEPLOY — private homeserver (home.zt):
    1. cp .env.example .env && \$EDITOR .env
    2. cshive private-setup      # deploy config files
    3. cshive start private      # start homeserver
    4. Configure Element: set homeserver URL to http://matrix.home.zt

FIRST DEPLOY — public homeserver (sibeling.org VPS):
    1. cshive verify             # check connectivity
    2. cshive vps-setup          # deploy config to VPS
    3. cshive vps-ufw            # configure firewall
    4. cshive start vps          # start homeserver

EXAMPLES:
    cshive start private        # start home.zt homeserver only
    cshive logs continuwuity-private  # tail private homeserver logs
    cshive start                # start all stacks
    cshive status               # show all service status
    cshive backup               # cold backup VPS RocksDB to /zfs/Backup/hive/collab/
    cshive update primary       # pull new bridge images and restart
    cshive vps-deploy-config    # push updated Caddyfile/continuwuity.toml to VPS
EOF
}

_load_vars() {
    load_env
    COLIMA_PROFILE="${COLIMA_PROFILE:-default}"
    CONTINUWUITY_PORT="${CONTINUWUITY_PORT:-6167}"
    PRIVATE_CONTINUWUITY_PORT="${PRIVATE_CONTINUWUITY_PORT:-6168}"
    PRIVATE_SERVER_NAME="${PRIVATE_SERVER_NAME:-home.zt}"
    COLLAB_BACKUP_ROOT="${COLLAB_BACKUP_ROOT:-/zfs/Backup/hive/collab}"
    COLLAB_VPS_CONFIG_ROOT="${COLLAB_VPS_CONFIG_ROOT:-/opt/collab}"
}

# ── SSH / SCP helpers ─────────────────────────────────────────────────────────

_ssh_vps() {
    local key_path="${COLLAB_VPS_SSH_KEY:-}"
    if [[ -n "${key_path}" ]]; then
        ssh -i "${key_path/#\~/${HOME}}" "${COLLAB_VPS_SSH_HOST}" "$@"
    else
        ssh "${COLLAB_VPS_SSH_HOST}" "$@"
    fi
}

_scp_to_vps() {
    local src="$1" dest="$2"
    local key_path="${COLLAB_VPS_SSH_KEY:-}"
    if [[ -n "${key_path}" ]]; then
        scp -i "${key_path/#\~/${HOME}}" "${src}" "${COLLAB_VPS_SSH_HOST}:${dest}"
    else
        scp "${src}" "${COLLAB_VPS_SSH_HOST}:${dest}"
    fi
}

# ── Compose helpers ───────────────────────────────────────────────────────────

_compose_primary() {
    export_docker_host
    require_docker
    docker compose -f "${PROJECT_ROOT}/docker-compose.yml" "$@"
}

_compose_private() {
    export_docker_host
    require_docker
    docker compose -f "${PROJECT_ROOT}/docker-compose.yml" --profile private "$@"
}

_compose_vps() {
    require_env COLLAB_VPS_SSH_HOST
    local key_opt=""
    if [[ -n "${COLLAB_VPS_SSH_KEY:-}" ]]; then
        key_opt="-o IdentityFile=${COLLAB_VPS_SSH_KEY/#\~/${HOME}}"
        export GIT_SSH_COMMAND="ssh ${key_opt}"
    fi
    DOCKER_HOST="ssh://${COLLAB_VPS_SSH_HOST}" \
        docker compose -f "${PROJECT_ROOT}/docker-compose.vps.yml" "$@"
}

# ── Lifecycle ─────────────────────────────────────────────────────────────────

run_start() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Starting VPS stack (Continuwuity + Caddy + wsproxy)"
            _compose_vps up -d
            log_ok "VPS stack started"
            ;;
        primary)
            log_step "Starting primary stack (bridges)"
            docker network create hive-net 2>/dev/null || true
            _compose_primary up -d
            log_ok "Primary stack started"
            ;;
        private)
            log_step "Starting private homeserver (${PRIVATE_SERVER_NAME})"
            docker network create hive-net 2>/dev/null || true
            _compose_private up -d continuwuity-private
            log_ok "Private homeserver started"
            log_info "Connect Element: set homeserver URL to http://matrix.${PRIVATE_SERVER_NAME}"
            ;;
        all)
            run_start vps
            run_start primary
            run_start private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_stop() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Stopping VPS stack"
            _compose_vps down
            log_ok "VPS stack stopped"
            ;;
        primary)
            log_step "Stopping primary stack"
            _compose_primary down
            log_ok "Primary stack stopped"
            ;;
        private)
            log_step "Stopping private homeserver"
            _compose_private down --remove-orphans
            log_ok "Private homeserver stopped"
            ;;
        all)
            run_stop private
            run_stop primary
            run_stop vps
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_restart() {
    local target="${1:-all}"
    run_stop "${target}"
    run_start "${target}"
}

run_status() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "VPS stack status"
            _compose_vps ps
            ;;
        primary)
            log_step "Primary stack status"
            _compose_primary ps
            ;;
        private)
            log_step "Private homeserver status"
            _compose_private ps continuwuity-private
            ;;
        all)
            run_status vps
            echo ""
            run_status primary
            echo ""
            run_status private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

run_update() {
    local target="${1:-all}"
    case "${target}" in
        vps)
            log_step "Updating VPS stack images"
            _compose_vps pull
            _compose_vps up -d
            log_ok "VPS stack updated"
            ;;
        primary)
            log_step "Updating primary stack images"
            _compose_primary pull
            _compose_primary up -d
            log_ok "Primary stack updated"
            ;;
        private)
            log_step "Updating private homeserver image"
            _compose_private pull continuwuity-private
            _compose_private up -d continuwuity-private
            log_ok "Private homeserver updated"
            ;;
        all)
            run_update vps
            run_update primary
            run_update private
            ;;
        *)
            log_error "Unknown target: ${target}. Use: vps, primary, private, or all"
            exit 1
            ;;
    esac
}

# ── Private Server Setup (home.zt) ───────────────────────────────────────────

run_private_setup() {
    require_env COLLAB_CONFIG_ROOT PRIVATE_SERVER_NAME PRIVATE_CONTINUWUITY_PORT

    local config_dir="${COLLAB_CONFIG_ROOT}/continuwuity-private"
    local toml_tpl="${PROJECT_ROOT}/config/continuwuity/continuwuity-private.toml.example"

    log_step "1/2 Creating config directory: ${config_dir}"
    mkdir -p "${config_dir}"
    log_ok "Directory ready"

    log_step "2/2 Deploying continuwuity.toml for ${PRIVATE_SERVER_NAME}"
    if [[ ! -f "${toml_tpl}" ]]; then
        log_error "Template not found: ${toml_tpl}"
        exit 1
    fi
    envsubst < "${toml_tpl}" > "${config_dir}/continuwuity.toml"
    log_ok "Config deployed to ${config_dir}/continuwuity.toml"
    log_warn "server_name is set to '${PRIVATE_SERVER_NAME}' — permanent after first start"

    log_ok "Private server setup complete"
    log_info "Next: cshive start private"
    log_info "Then: configure Element homeserver URL → http://matrix.${PRIVATE_SERVER_NAME}"
    log_info "After creating your account, set allow_registration = false in the config"
    log_info "and run: cshive restart private"
}

# ── VPS Setup ────────────────────────────────────────────────────────────────

run_vps_setup() {
    require_env COLLAB_VPS_SSH_HOST COLLAB_VPS_CONFIG_ROOT \
                MATRIX_SERVER_NAME MATRIX_DOMAIN CONTINUWUITY_PORT ACME_EMAIL

    log_step "1/4 Creating VPS directory structure at ${COLLAB_VPS_CONFIG_ROOT}"
    _ssh_vps "mkdir -p ${COLLAB_VPS_CONFIG_ROOT}/{continuwuity,caddy,wsproxy}"
    log_ok "Directories created"

    log_step "2/4 Deploying Caddyfile"
    _scp_to_vps \
        "${PROJECT_ROOT}/config/caddy/Caddyfile.example" \
        "${COLLAB_VPS_CONFIG_ROOT}/caddy/Caddyfile"
    log_ok "Caddyfile deployed (Caddy resolves {\$VAR} env vars at runtime)"

    log_step "3/4 Deploying continuwuity.toml"
    local toml_tpl="${PROJECT_ROOT}/config/continuwuity/continuwuity.toml.example"
    if [[ ! -f "${toml_tpl}" ]]; then
        log_error "Template not found: ${toml_tpl}"
        exit 1
    fi
    envsubst < "${toml_tpl}" | \
        _ssh_vps "cat > ${COLLAB_VPS_CONFIG_ROOT}/continuwuity/continuwuity.toml"
    log_ok "continuwuity.toml deployed (MATRIX_SERVER_NAME=${MATRIX_SERVER_NAME})"

    log_step "4/4 Verifying Docker on VPS"
    if _ssh_vps "docker --version" 2>/dev/null; then
        log_ok "Docker available on VPS"
    else
        log_error "Docker not found on VPS"
        log_info  "Install: curl -fsSL https://get.docker.com | sh"
        exit 1
    fi

    log_ok "VPS setup complete"
    log_info "Next steps:"
    log_info "  cshive vps-ufw    — configure UFW firewall rules"
    log_info "  cshive start vps  — deploy and start the homeserver"
}

run_vps_ufw() {
    require_env COLLAB_VPS_SSH_HOST ZT_SUBNET CONTINUWUITY_PORT

    log_step "Configuring UFW on VPS (ZeroTier subnet: ${ZT_SUBNET})"

    # Public ports — Matrix federation and client API via Caddy
    _ssh_vps "sudo ufw allow 80/tcp comment 'Caddy ACME HTTP-01'"
    _ssh_vps "sudo ufw allow 443/tcp comment 'Matrix client-server API'"
    _ssh_vps "sudo ufw allow 8448/tcp comment 'Matrix server-to-server federation'"

    # ZeroTier-only — homeserver API for bridges and MCP server on primary node
    _ssh_vps "sudo ufw allow from ${ZT_SUBNET} to any port ${CONTINUWUITY_PORT} proto tcp comment 'Matrix homeserver API (ZeroTier only)'"

    # ZeroTier-only — wsproxy for iMessage satellite (Mac Mini)
    _ssh_vps "sudo ufw allow from ${ZT_SUBNET} to any port 29331 proto tcp comment 'mautrix-wsproxy (ZeroTier only)'"

    log_ok "UFW rules applied"
    _ssh_vps "sudo ufw status numbered"
}

run_vps_deploy_config() {
    require_env COLLAB_VPS_SSH_HOST COLLAB_VPS_CONFIG_ROOT \
                MATRIX_SERVER_NAME MATRIX_DOMAIN CONTINUWUITY_PORT ACME_EMAIL

    log_step "Re-deploying config files to VPS"

    log_info "Deploying Caddyfile"
    _scp_to_vps \
        "${PROJECT_ROOT}/config/caddy/Caddyfile.example" \
        "${COLLAB_VPS_CONFIG_ROOT}/caddy/Caddyfile"

    log_info "Deploying continuwuity.toml"
    envsubst < "${PROJECT_ROOT}/config/continuwuity/continuwuity.toml.example" | \
        _ssh_vps "cat > ${COLLAB_VPS_CONFIG_ROOT}/continuwuity/continuwuity.toml"

    log_ok "Config files deployed"
    log_info "Restart the VPS stack to apply: cshive restart vps"
}

# ── Backup ────────────────────────────────────────────────────────────────────

run_backup() {
    require_env COLLAB_VPS_SSH_HOST COLLAB_PRIMARY_ZT_IP
    local today; today="$(date +%Y-%m-%d)"
    local dest="${COLLAB_BACKUP_ROOT}/${today}"
    local latest="${COLLAB_BACKUP_ROOT}/latest"

    log_step "Starting cold backup of VPS RocksDB → ${dest}"
    log_warn "VPS services will be stopped briefly (~30–60s)"

    log_step "1/4 Stopping VPS stack"
    _compose_vps down

    log_step "2/4 Resolving volume path on VPS"
    local vol_path
    vol_path="$(DOCKER_HOST="ssh://${COLLAB_VPS_SSH_HOST}" \
        docker volume inspect collab-vps_collab_continuwuity_data \
        --format '{{.Mountpoint}}' 2>/dev/null)" || {
        log_warn "Volume not found — homeserver may not have been started yet"
        vol_path=""
    }

    if [[ -n "${vol_path}" ]]; then
        log_step "3/4 Rsyncing ${COLLAB_VPS_SSH_HOST}:${vol_path}/ → ${dest}/"
        mkdir -p "${dest}"
        local link_arg=""
        [[ -d "${latest}" ]] && link_arg="--link-dest=${latest}"
        rsync -az --delete ${link_arg} \
            "${COLLAB_VPS_SSH_HOST}:${vol_path}/" \
            "${dest}/"
        ln -sfn "${dest}" "${latest}"
        log_ok "Backup complete: ${dest}"
    else
        log_warn "Skipping rsync — no volume data found (nothing to back up yet)"
    fi

    log_step "4/4 Restarting VPS stack"
    _compose_vps up -d
    log_ok "VPS stack restarted"

    log_step "Rotating old backups (keeping last 30 days)"
    _rotate_backups
}

_rotate_backups() {
    local cutoff; cutoff="$(date -v-31d +%Y-%m-%d 2>/dev/null || date -d '31 days ago' +%Y-%m-%d)"
    local count=0
    for dir in "${COLLAB_BACKUP_ROOT}"/????-??-??; do
        [[ -d "${dir}" ]] || continue
        local name; name="$(basename "${dir}")"
        if [[ "${name}" < "${cutoff}" ]]; then
            rm -rf "${dir}"
            (( count++ ))
        fi
    done
    [[ ${count} -gt 0 ]] && log_info "Removed ${count} backup(s) older than 30 days"
}

# ── Verify ────────────────────────────────────────────────────────────────────

run_verify() {
    local ok=true
    require_env COLLAB_VPS_ZT_IP COLLAB_PRIMARY_ZT_IP COLLAB_VPS_SSH_HOST MATRIX_DOMAIN

    log_step "1. ZeroTier connectivity to VPS (${COLLAB_VPS_ZT_IP})"
    if ping -c 1 -W 2 "${COLLAB_VPS_ZT_IP}" &>/dev/null; then
        log_ok "VPS ZeroTier reachable"
    else
        log_error "Cannot ping VPS at ${COLLAB_VPS_ZT_IP}"
        log_info  "Check: is ZeroTier running? Is the VPS joined to the network?"
        ok=false
    fi

    log_step "2. VPS SSH reachable"
    if ssh -o ConnectTimeout=5 -o BatchMode=yes "${COLLAB_VPS_SSH_HOST}" true 2>/dev/null; then
        log_ok "VPS SSH reachable"
    else
        log_error "SSH to ${COLLAB_VPS_SSH_HOST} failed"
        log_info  "Check: correct key in COLLAB_VPS_SSH_KEY? VPS SSH service running?"
        ok=false
    fi

    log_step "3. VPS Docker daemon reachable"
    if DOCKER_HOST="ssh://${COLLAB_VPS_SSH_HOST}" docker info &>/dev/null 2>&1; then
        log_ok "VPS Docker reachable"
    else
        log_error "Cannot reach Docker on VPS via SSH"
        log_info  "Check: is Docker installed and running on the VPS?"
        ok=false
    fi

    log_step "4. Homeserver health (${COLLAB_VPS_ZT_IP}:${CONTINUWUITY_PORT})"
    local hs_url="http://${COLLAB_VPS_ZT_IP}:${CONTINUWUITY_PORT}/_matrix/client/versions"
    if curl -sf --max-time 5 "${hs_url}" -o /dev/null; then
        log_ok "Homeserver responding at ${hs_url}"
    else
        log_warn "Homeserver not responding at ${hs_url} (expected if not yet deployed)"
    fi

    log_step "5. Local Docker (Colima) reachable"
    if colima_running "${COLIMA_PROFILE}"; then
        log_ok "Colima (profile: ${COLIMA_PROFILE}) running"
    else
        log_warn "Colima not running — bridge stack cannot start"
        log_info  "Start: colima start --profile ${COLIMA_PROFILE}"
    fi

    log_step "6. hive-net bridge exists"
    export_docker_host
    if docker network ls --format '{{.Name}}' 2>/dev/null | grep -q '^hive-net$'; then
        log_ok "hive-net bridge present"
    else
        log_warn "hive-net not found — run: docker network create hive-net"
        log_info  "Or: cshive start primary (creates it automatically)"
    fi

    echo ""
    if $ok; then
        log_ok "All required checks passed"
    else
        log_error "Some checks failed — resolve issues before deploying"
        exit 1
    fi
}

# ── Logs ──────────────────────────────────────────────────────────────────────

run_logs() {
    local service="${1:?Usage: cshive logs <service>}"
    case "${service}" in
        signal|whatsapp|discord)
            _compose_primary logs -f "${service}" ;;
        continuwuity-private)
            _compose_private logs -f continuwuity-private ;;
        continuwuity|wsproxy|caddy)
            _compose_vps logs -f "${service}" ;;
        *)
            log_error "Unknown service: ${service}"
            log_info  "Valid: signal, whatsapp, discord, continuwuity, continuwuity-private, wsproxy, caddy"
            exit 1
            ;;
    esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true
    [[ "${cmd}" == "help" || "${cmd}" == "--help" || "${cmd}" == "-h" ]] && { usage; exit 0; }
    _load_vars
    case "${cmd}" in
        start)   run_start   "${1:-all}" ;;
        stop)    run_stop    "${1:-all}" ;;
        restart) run_restart "${1:-all}" ;;
        status)  run_status  "${1:-all}" ;;
        update)  run_update  "${1:-all}" ;;
        private-setup)      run_private_setup ;;
        vps-setup)          run_vps_setup ;;
        vps-ufw)            run_vps_ufw ;;
        vps-deploy-config)  run_vps_deploy_config ;;
        backup)  run_backup ;;
        verify)  run_verify ;;
        logs)    run_logs "$@" ;;
        *) log_error "Unknown command: ${cmd}"; usage; exit 1 ;;
    esac
}

main "$@"
