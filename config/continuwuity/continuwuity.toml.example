# continuwuity.toml — Continuwuity homeserver configuration (VPS / sibeling.org)
# This is a template. Deploy with: cshive vps-setup or cshive vps-deploy-config
# Variables (${...}) are substituted from .env by cshive using envsubst.

[global]
server_name = "${MATRIX_SERVER_NAME}"
database_backend = "rocksdb"
database_path = "/var/lib/continuwuity"

# Listen on all interfaces. Port ${CONTINUWUITY_PORT} is bound on the VPS host —
# UFW (cshive vps-ufw) restricts it to ZeroTier subnet only.
address = "0.0.0.0"
port = ${CONTINUWUITY_PORT}

# Registration shared secret for appservice and admin account creation.
# Substituted at deploy time — not stored in source control.
registration_shared_secret = "${CONTINUWUITY_REGISTRATION_SHARED_SECRET}"

# Maximum upload size in bytes. 20MB covers most bridge media; increase if
# WhatsApp or Signal groups send larger files.
max_request_size = 20971520

# Federation — required for bridges and external communication.
allow_federation = true

# Registration — keep closed; bridges use appservice tokens, not open signup.
allow_registration = false
allow_guest_registration = false

allow_encryption = true
allow_room_creation = true
allow_unstable_room_versions = true

trusted_servers = ["matrix.org"]

log = "warn,state_res=warn"

# ── Appservice Bridges (Phase 2) ──────────────────────────────────────────────
# Uncomment and add each bridge's registration YAML as it is deployed.
# Registration YAMLs are generated by the bridge container on first run and
# must be copied to COLLAB_VPS_CONFIG_ROOT/continuwuity/ before adding here.
# After editing: cshive vps-deploy-config && cshive restart vps
#
# app_service_config_files = [
#     "/etc/continuwuity/whatsapp-registration.yaml",
#     "/etc/continuwuity/signal-registration.yaml",
#     "/etc/continuwuity/discord-registration.yaml",
#     "/etc/continuwuity/wsproxy-registration.yaml",
# ]
